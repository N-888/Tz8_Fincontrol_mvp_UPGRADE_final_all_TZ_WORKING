# Указываем секретный ключ Django для локальной разработки.
DJANGO_SECRET_KEY=your-secret-key-here

# Указываем режим отладки для локального запуска.
DJANGO_DEBUG=True

# Указываем список разрешённых хостов через запятую.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Указываем токен Telegram-бота, т.е. ключ, который выдаёт BotFather.
TELEGRAM_BOT_TOKEN=replace-this-with-your-telegram-token
# replace-this-with-your-telegram-token

# Указываем часовой пояс проекта.
DJANGO_TIME_ZONE=Europe/Moscow

# Это ключ доступа к OpenAI API.
# Он нужен только для дополнительных платных функций проекта.
# Если ключ не указан, бесплатные советы и обычный режим работы остаются.
# Вместо текста "твой_ключ" нужно вставить настоящий ключ OpenAI API.
OPENAI_API_KEY=твой_ключ

# Это название модели для расширенных AI-подсказок.
# Она используется только если пользователь сам включил AI-опцию в профиле.
# Бесплатные обычные советы проекта работают и без этой строки.
OPENAI_ADVICE_MODEL=gpt-4.1-mini

# Это название модели для распознавания голосовых сообщений из Telegram.
# Она используется только если пользователь сам включил голосовую опцию в профиле.
# Если голосовая опция не нужна, проект всё равно работает без этой функции.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe